{
  "name": "high-school-sports-master-db",
  "version": "0.1.0",
  "description": "Master database: high schools + professional athletes (US & international)",
  "type": "module",
  "scripts": {
    "load": "tsx scripts/load-master-db.ts",
    "export": "tsx scripts/export_csv.ts",
    "ingest": "python scripts/ingest_all_players.py",
    "audit": "python scripts/validate_schema.py && python scripts/audit_database.py",
    "validate": "python scripts/validate_schema.py",
    "build:education": "python scripts/build_education_index.py",
    "api:dev": "vercel dev"
  },
  "devDependencies": {
    "@vercel/node": "^3.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@nhl-api/players": "^3.1.4"
  }
}
